# ------------------------------
# Unity default ignore
# ------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
UserSettings/
MemoryCaptures/

# ------------------------------
# Crash logs
# ------------------------------
*.stackdump

# ------------------------------
# Visual Studio / Rider / IDE
# ------------------------------
.vscode/
.vs/
*.csproj
*.sln
*.pidb
*.pdb
*.user
*.unitypackage
*.tmp

# ------------------------------
# Auto-generated
# ------------------------------
*.mdb
*.svd

# ------------------------------
# IGNORE COPYRIGHTED GAMEDEV.TV PACK
# (Exact folder name from your project)
Assets/GameDev.tv - Delivery Dash Assets/

# ------------------------------
# IGNORE Prefabs + Art + Audio from asset packs
# ------------------------------
Assets/**/Prefabs/
Assets/**/Materials/
Assets/**/Textures/
Assets/**/Models/
Assets/**/Sprites/
Assets/**/VFX/
Assets/**/Audio/
Assets/**/Art/

# ------------------------------
# Allow your own game code
# ------------------------------
!Assets/**/Scripts/
!Assets/**/Scenes/

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/

# IDE ignores
.vscode/
.vs/
*.csproj
*.sln
*.pdb
*.unitypackage

# IGNORE copyrighted pack
Assets/GameDev.tv - Delivery Dash Assets/

# IGNORE prefab folder (asset pack prefabs)
Assets/Prefebs/

# Allow your code
!Assets/**/Scripts/
!Assets/**/Scenes/
# Ignore all prefabs
Assets/**/Prefabs/
Assets/**/Prefabs.meta
Assets/**/Prefebs/
Assets/**/Prefebs.meta
# IGNORE FULL COPYRIGHTED GAMEDEV.TV PACK
Assets/GameDev.tv - Delivery Dash Assets/
Assets/GameDev.tv - Delivery Dash Assets.meta
# Ignore Prefebs asset pack prefabs (exact folder name)
Assets/Prefebs/
Assets/Prefebs.meta
Assets/Prefebs/**
# IGNORE FULL COPYRIGHTED GAMEDEV.TV PACK
Assets/GameDev.tv - Delivery Dash Assets/
Assets/GameDev.tv - Delivery Dash Assets.meta

# IGNORE prefab folder and all prefab files from asset packs
Assets/Prefebs/
Assets/Prefebs.meta
Assets/Prefebs/**

GameDev.tv - Delivery Dash Assets.meta
Assets/Prefebs/
Assets/Prefebs/*.prefab
Assets/Prefebs/*.prefab.meta
