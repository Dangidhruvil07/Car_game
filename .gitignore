Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/

# ------------------------------
# IDE files
# ------------------------------
.vs/
.vscode/
*.csproj
*.sln
*.user
*.pdb
*.unitypackage

# ------------------------------
# Ignore copyrighted assets
# ------------------------------
Assets/GameDev.tv - Delivery Dash Assets/

# Ignore heavy asset types
Assets/**/Textures/
Assets/**/Models/
Assets/**/Audio/
Assets/**/Materials/
Assets/**/Sprites/
Assets/**/VFX/

# ------------------------------
# Allow important game files
# ------------------------------
!Assets/**/Scripts/
!Assets/**/Scenes/